@model List<PortalRH.Departamento>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Portal RH - Departamentos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body{background:#f0f2f5}
        .topbar{background:#0f6e56;padding:12px 24px;display:flex;align-items:center;justify-content:space-between}
        .topbar a{color:rgba(255,255,255,.75);text-decoration:none;margin-right:16px}
        .topbar a:hover{color:#fff}
        .topbar span{color:#fff;font-weight:bold}
        .btn-rh{background:#0f6e56;color:#fff;border:none}
        .btn-rh:hover{background:#085041;color:#fff}
        .badge-rh{background:#e1f5ee;color:#0f6e56;padding:4px 8px;border-radius:6px;font-size:12px}
    </style>
</head>
<body>
<div class="topbar">
    <span>Portal RH</span>
    <div>
        <a href="/Dashboard/Index">Dashboard</a>
        <a href="/Funcionario/Index">Funcionarios</a>
        <a href="/Departamento/Index">Departamentos</a>
    </div>
    <div>
        <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
            <button class="btn btn-outline-light btn-sm">Sair</button>
        </form>
    </div>
</div>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0">Departamentos</h5>
        <a href="/Departamento/Novo" class="btn btn-rh">+ Novo departamento</a>
    </div>
    <div class="row g-3">
        @foreach (var depto in Model)
        {
            <div class="col-md-6">
                <div class="card border-0 shadow-sm p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="mb-0">@depto.Nome</h6>
                        <span class="badge-rh">@depto.Funcionarios.Count funcionarios</span>
                    </div>
                    <div class="text-muted small mb-3">
                        Total folha: <strong>R$ @depto.CalcularFolha().ToString("N0")</strong>
                    </div>
                    @foreach (var func in depto.Funcionarios)
                    {
                        <div class="d-flex justify-content-between py-1 border-top">
                            <span class="small">@func.Nome</span>
                            <span class="small text-muted">@func.Cargo</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
</body>
</html>