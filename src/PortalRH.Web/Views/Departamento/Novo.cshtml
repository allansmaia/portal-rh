@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Portal RH - Novo Departamento</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; }
        .navbar-rh { background-color: #0f6e56; }
        .nav-link-rh { color: rgba(255,255,255,0.75); text-decoration: none; }
        .nav-link-rh:hover { color: white; }
        .btn-rh { background-color: #0f6e56; color: white; border: none; }
        .btn-rh:hover { background-color: #085041; color: white; }
    </style>
</head>
<body>
    <nav class="navbar-rh d-flex align-items-center justify-content-between px-4 py-3">
        <span class="text-white fw-bold">Portal RH</span>
        <div class="d-flex gap-4">
            <a href="/Dashboard/Index" class="nav-link-rh">Dashboard</a>
            <a href="/Funcionario" class="nav-link-rh">Funcionarios</a>
            <a href="/Departamento" class="nav-link-rh">Departamentos</a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
            </form>
        </div>
    </nav>
    <div class="container py-4">
        <div class="mb-4">
            <a href="/Departamento" class="text-muted text-decoration-none">← Voltar</a>
        </div>
        <div class="card border-0 shadow-sm p-4" style="max-width: 500px;">
            <h5 class="mb-4">Novo departamento</h5>
            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger">@ViewBag.Erro</div>
            }
            <form asp-controller="Departamento" asp-action="Novo" method="post">
                <div class="mb-4">
                    <label class="form-label">Nome do departamento</label>
                    <input type="text" name="nome" class="form-control" placeholder="Ex: Financeiro" />
                </div>
                <button type="submit" class="btn btn-rh w-100">Cadastrar</button>
            </form>
        </div>
    </div>
</body>
</html>