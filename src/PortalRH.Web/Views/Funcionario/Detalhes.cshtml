@model PortalRH.Funcionario
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Portal RH - Detalhes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; }
        .navbar-rh { background-color: #0f6e56; }
        .nav-link-rh { color: rgba(255,255,255,0.75); text-decoration: none; }
        .nav-link-rh:hover { color: white; }
        .info-card { border-left: 4px solid #0f6e56; }
    </style>
</head>
<body>
    <nav class="navbar-rh d-flex align-items-center justify-content-between px-4 py-3">
        <span class="text-white fw-bold">Portal RH</span>
        <div class="d-flex gap-4">
            <a href="/Dashboard/Index" class="nav-link-rh">Dashboard</a>
            <a href="/Funcionario" class="nav-link-rh">Funcionarios</a>
            <a href="/Departamento" class="nav-link-rh">Departamentos</a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
            </form>
        </div>
    </nav>
    <div class="container py-4">
        <div class="mb-4">
            <a href="/Funcionario" class="text-muted text-decoration-none">← Voltar</a>
        </div>
        <div class="card border-0 shadow-sm p-4 mb-3">
            <h5 class="mb-1">@Model.Nome</h5>
            <span class="text-muted">@Model.Cargo</span>
        </div>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-3 info-card">
                    <div class="text-muted small mb-1">Salario</div>
                    <div class="fw-bold fs-5">R$ @Model.Salario.ToString("N2")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-3 info-card">
                    <div class="text-muted small mb-1">Bonus (10%)</div>
                    <div class="fw-bold fs-5">R$ @Model.CalcularBonus(10).ToString("N2")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-3 info-card">
                    <div class="text-muted small mb-1">Ferias</div>
                    <div class="fw-bold fs-5">R$ @Model.CalcularFerias().ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>