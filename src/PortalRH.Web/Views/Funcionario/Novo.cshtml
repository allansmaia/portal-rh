@model PortalRH.Funcionario
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Portal RH - Novo Funcionario</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; }
        .navbar-rh { background-color: #0f6e56; }
        .nav-link-rh { color: rgba(255,255,255,0.75); text-decoration: none; }
        .nav-link-rh:hover { color: white; }
        .btn-rh { background-color: #0f6e56; color: white; border: none; }
        .btn-rh:hover { background-color: #085041; color: white; }
    </style>
</head>
<body>
    <nav class="navbar-rh d-flex align-items-center justify-content-between px-4 py-3">
        <span class="text-white fw-bold">Portal RH</span>
        <div class="d-flex gap-4">
            <a href="/Dashboard" class="nav-link-rh">Dashboard</a>
            <a href="/Funcionario" class="nav-link-rh active">Funcionarios</a>
            <a href="/Departamento" class="nav-link-rh">Departamentos</a>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
        </form>
    </nav>
    <div class="container py-4">
        <div class="mb-4">
            <a href="/Funcionario" class="text-muted text-decoration-none">← Voltar</a>
        </div>
        <div class="card border-0 shadow-sm p-4" style="max-width: 500px;">
            <h5 class="mb-4">Novo Funcionario</h5>
            <form asp-action="Novo" method="post">
                <div class="mb-3">
                    <label asp-for="Nome" class="form-label">Nome</label>
                    <input asp-for="Nome" class="form-control" placeholder="Nome completo" required />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Cargo" class="form-label">Cargo</label>
                    <input asp-for="Cargo" class="form-control" placeholder="Cargo do funcionario" required />
                    <span asp-validation-for="Cargo" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Salario" class="form-label">Salario</label>
                    <input asp-for="Salario" type="number" step="0.01" class="form-control" placeholder="0,00" required />
                    <span asp-validation-for="Salario" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="DataAdmissao" class="form-label">Data de Admissao</label>
                    <input asp-for="DataAdmissao" type="date" class="form-control" required />
                    <span asp-validation-for="DataAdmissao" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-rh w-100">Cadastrar</button>
            </form>
        </div>
    </div>
</body>
</html>