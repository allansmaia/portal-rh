@model PortalRH.Web.Services.DashboardViewModel
@{
    Layout = null;
    var usuario = User.Identity != null ? User.Identity.Name : "Usuario";
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Portal RH - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background: #f0f2f5; }
        .navbar-rh { background: #0f6e56; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; }
        .nav-link-rh { color: rgba(255,255,255,.75); text-decoration: none; margin-right: 16px; }
        .nav-link-rh:hover { color: #fff; }
        .nav-link-rh.active { color: #fff; font-weight: 600; }
        .navbar-brand { color: #fff; font-weight: bold; }
        .stat-card { border: none; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-4px); }
        .stat-icon { width: 56px; height: 56px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 26px; }
        .card-custom { border: none; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
        .section-title { font-size: 18px; font-weight: 600; color: #1a1a2e; margin-bottom: 20px; }
        .badge-rh { background: #e8f5f2; color: #0f6e56; }
        .btn-rh { background: #0f6e56; color: white; border: none; }
        .btn-rh:hover { background: #085041; color: white; }
        .welcome-card { background: linear-gradient(135deg, #0f6e56 0%, #17a085 100%); border-radius: 16px; color: white; }
        .quick-action { border-radius: 12px; padding: 16px; text-align: center; transition: all 0.2s; display: block; }
        .quick-action:hover { background: #f8f9fa; transform: translateY(-2px); text-decoration: none; }
        .quick-action i { font-size: 28px; color: #0f6e56; }
        .table-modern { margin-bottom: 0; }
        .table-modern thead th { border-bottom: 2px solid #0f6e56; color: #0f6e56; }
    </style>
</head>
<body>
    <nav class="navbar-rh">
        <span class="navbar-brand">Portal RH</span>
        <div>
            <a href="/Dashboard" class="nav-link-rh active">Dashboard</a>
            <a href="/Funcionario" class="nav-link-rh">Funcionarios</a>
            <a href="/Departamento" class="nav-link-rh">Departamentos</a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span style="color:rgba(255,255,255,.85)">Ola, <strong>@usuario</strong></span>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button class="btn btn-outline-light btn-sm">Sair</button>
            </form>
        </div>
    </nav>

    <div class="container py-4">
        <div class="welcome-card p-4 mb-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h4 class="mb-2">Bem-vindo ao Portal RH!</h4>
                    <p class="mb-0 opacity-75">Gerencie seus funcionarios de forma simples e eficiente.</p>
                </div>
                <div class="col-md-4 text-end">
                    <a href="/Funcionario/Novo" class="btn btn-light btn-lg">
                        <i class="bi bi-person-plus"></i> Novo Funcionario
                    </a>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card stat-card p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-success bg-opacity-10 text-success">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Total Funcionarios</div>
                            <div class="fw-bold fs-3">@Model.TotalFuncionarios</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-cash-stack"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Folha de Pagamento</div>
                            <div class="fw-bold fs-5">R$ @Model.TotalFolha.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                            <i class="bi bi-graph-up"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Media Salarial</div>
                            <div class="fw-bold fs-5">R$ @Model.MediaSalarial.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-info bg-opacity-10 text-info">
                            <i class="bi bi-star-fill"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Maior Salario</div>
                            <div class="fw-bold fs-6">@Model.MaiorSalarioNome</div>
                            <div class="text-muted small">R$ @Model.MaiorSalario.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                @if (Model.FuncionariosPorCargo.Any())
                {
                    <div class="card card-custom p-4">
                        <h6 class="section-title mb-3">
                            <i class="bi bi-bar-chart-fill me-2"></i>Distribuicao por Cargo
                        </h6>
                        <table class="table table-modern">
                            <thead>
                                <tr>
                                    <th>Cargo</th>
                                    <th class="text-center">Quantidade</th>
                                    <th class="text-center">Percentual</th>
                                    <th style="width: 200px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.FuncionariosPorCargo)
                                {
                                    <tr>
                                        <td><span class="badge badge-rh">@item.Cargo</span></td>
                                        <td class="text-center fw-medium">@item.Quantidade</td>
                                        <td class="text-center">@((item.Quantidade * 100.0 / Model.TotalFuncionarios).ToString("F1"))%</td>
                                        <td>
                                            <div class="progress mb-0" style="height: 8px;">
                                                <div class="progress-bar" style="width: @((item.Quantidade * 100.0 / Model.TotalFuncionarios))%; background: #0f6e56;"></div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="col-md-4">
                <div class="card card-custom p-4">
                    <h6 class="section-title mb-4">
                        <i class="bi bi-lightning-fill me-2"></i>Acoes Rapidas
                    </h6>
                    <div class="d-flex flex-column gap-3">
                        <a href="/Funcionario/Novo" class="quick-action bg-success bg-opacity-10">
                            <i class="bi bi-person-plus text-success"></i>
                            <div class="mt-2 small text-dark fw-medium">Novo Funcionario</div>
                        </a>
                        <a href="/Funcionario" class="quick-action bg-primary bg-opacity-10">
                            <i class="bi bi-search text-primary"></i>
                            <div class="mt-2 small text-dark fw-medium">Buscar Funcionario</div>
                        </a>
                        <a href="/Funcionario" class="quick-action bg-warning bg-opacity-10">
                            <i class="bi bi-list-ul text-warning"></i>
                            <div class="mt-2 small text-dark fw-medium">Ver Lista</div>
                        </a>
                        <a href="/Departamento" class="quick-action bg-danger bg-opacity-10">
                            <i class="bi bi-building text-danger"></i>
                            <div class="mt-2 small text-dark fw-medium">Departamentos</div>
                        </a>
                    </div>
                </div>

                @if (Model.NovoFuncionario != null)
                {
                    <div class="card card-custom p-4 mt-4">
                        <h6 class="section-title mb-3">
                            <i class="bi bi-person-badge me-2"></i>Recem-Admitido
                        </h6>
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background: #0f6e56;">
                                <span class="text-white fw-bold">@Model.NovoFuncionario.Nome[0]</span>
                            </div>
                            <div>
                                <div class="fw-semibold">@Model.NovoFuncionario.Nome</div>
                                <div class="small text-muted">@Model.NovoFuncionario.Cargo</div>
                                <div class="small text-muted">Admitido em @Model.NovoFuncionario.DataAdmissao.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</body>
</html>